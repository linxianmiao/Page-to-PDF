{
  "manifest_version": 3,
  "name": "Page2PDF 网页转 PDF",
  "version": "2.0.0",
  "description": "飞书式滚动截图:用户自定义范围,滚动到哪截到哪,最后在编辑器里画分割线导出 PDF。",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "网页保存为 PDF",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
